---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const notes = await getCollection('notes');
const domains = [...new Set(notes.map((n) => n.data.domain))].sort();
const base = import.meta.env.BASE_URL;
const toSlug = (s: string) => s.toLowerCase().replace(/\s+/g, '-');
---
<BaseLayout title="Practical Notes (Collections)">
  <h1>Practical Notes <small>(Collections)</small></h1>
  <p>
    用 Astro Content Collections 從零搭建的學習筆記網站。對照實作版本是
    <a href="https://Beny942k6xu4.github.io/Practical-Starlight/">Practical-Starlight</a>。
  </p>

  <h2>邏輯模型</h2>
  <pre><code>{`Meta (Study root)
 └── Domain        (e.g. Server)
      └── Subdomain  (e.g. PowerShell)
           └── Topic     (e.g. basic-learn)
                └── Skill     (e.g. rename)
                     └── Concept   (e.g. Path)`}</code></pre>
  <p>結構是邏輯的，不是物理的。詳見 <a href={`${base}meta/principles/`}>知識組織原則</a>。</p>

  <h2>Domains</h2>
  <ul>
    {domains.map((d) => (
      <li><a href={`${base}domains/${toSlug(d)}/`}>{d}</a></li>
    ))}
  </ul>

  <h2>所有 notes（{notes.length}）</h2>
  <ul>
    {notes.map((n) => (
      <li>
        <a href={`${base}domains/${n.id.replace(/\.(md|mdx)$/, '')}/`}>{n.data.title}</a>
        {n.data.description && <> — {n.data.description}</>}
      </li>
    ))}
  </ul>
</BaseLayout>
