---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const notes = await getCollection(
  'notes',
  (n) =>
    n.data.domain === 'Server' &&
    n.data.subdomain === 'PowerShell' &&
    n.data.topic === 'basic-learn'
);
const skills = [...new Set(notes.map((n) => n.data.skill).filter((x): x is string => Boolean(x)))].sort();
const base = import.meta.env.BASE_URL;

const toSlug = (s: string) => s.toLowerCase().replace(/\s+/g, '-');
---
<BaseLayout title="basic-learn" description="PowerShell 子領域下的基礎學習主題。">
  <p>
    <span class="meta-pill">topic: basic-learn</span>
  </p>
  <h1>basic-learn</h1>
  <p>PowerShell 的基礎學習主題。每個 skill 代表一種具體可練的能力。</p>

  <h2>Skills</h2>
  <ul>
    {skills.map((s) => (
      <li><a href={`${base}domains/server/powershell/basic-learn/${toSlug(s)}/`}>{s}</a></li>
    ))}
  </ul>

  <h2>本主題所有筆記（{notes.length}）</h2>
  <ul>
    {notes.map((n) => (
      <li>
        <a href={`${base}domains/${n.id.replace(/\.(md|mdx)$/, '')}/`}>{n.data.title}</a>
        {n.data.description && <> — {n.data.description}</>}
      </li>
    ))}
  </ul>
</BaseLayout>
