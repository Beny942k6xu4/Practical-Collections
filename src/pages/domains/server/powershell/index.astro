---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const notes = await getCollection(
  'notes',
  (n) => n.data.domain === 'Server' && n.data.subdomain === 'PowerShell'
);
const topics = [...new Set(notes.map((n) => n.data.topic).filter((x): x is string => Boolean(x)))].sort();
const base = import.meta.env.BASE_URL;

const toSlug = (s: string) => s.toLowerCase().replace(/\s+/g, '-');
---
<BaseLayout title="PowerShell" description="Server 領域下的 PowerShell 子領域筆記。">
  <p>
    <span class="meta-pill">domain: Server</span>
    <span class="meta-pill">subdomain: PowerShell</span>
  </p>
  <h1>PowerShell</h1>
  <p>Server 領域下的 PowerShell 子領域。Cmdlet、參數、實作筆記。</p>

  <h2>Topics</h2>
  <ul>
    {topics.map((t) => (
      <li><a href={`${base}domains/server/powershell/${toSlug(t)}/`}>{t}</a></li>
    ))}
  </ul>

  <h2>本子領域所有筆記（{notes.length}）</h2>
  <ul>
    {notes.map((n) => (
      <li>
        <a href={`${base}domains/${n.id.replace(/\.(md|mdx)$/, '')}/`}>{n.data.title}</a>
        {n.data.description && <> — {n.data.description}</>}
      </li>
    ))}
  </ul>

  <h2>外部參考</h2>
  <ul>
    <li><a href="https://learn.microsoft.com/zh-tw/powershell/">Microsoft Learn — PowerShell</a></li>
  </ul>
</BaseLayout>
