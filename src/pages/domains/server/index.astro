---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const notes = await getCollection('notes', (n) => n.data.domain === 'Server');
const subdomains = [
  ...new Set(notes.map((n) => n.data.subdomain).filter((x): x is string => Boolean(x))),
].sort();
const base = import.meta.env.BASE_URL;

const toSlug = (s: string) => s.toLowerCase().replace(/\s+/g, '-');
---
<BaseLayout title="Server" description="Server 領域：作業系統與管理工具相關的實作筆記。">
  <p>
    <span class="meta-pill">domain</span>
  </p>
  <h1>Server</h1>
  <p>Server 領域入口。涵蓋作業系統管理、shell、服務、網路等實作筆記。</p>

  <h2>Subdomains</h2>
  <ul>
    {subdomains.map((s) => (
      <li><a href={`${base}domains/server/${toSlug(s)}/`}>{s}</a></li>
    ))}
  </ul>

  <h2>本領域所有筆記（{notes.length}）</h2>
  <ul>
    {notes.map((n) => (
      <li>
        <a href={`${base}domains/${n.id.replace(/\.(md|mdx)$/, '')}/`}>{n.data.title}</a>
        {n.data.description && <> — {n.data.description}</>}
      </li>
    ))}
  </ul>
</BaseLayout>
